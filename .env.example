# Copy this file to .env and fill in your real values.
# .env is gitignored - never commit real API keys.

# --- Classifier ---
# "gemini" needs no training/model file, just an API key below.
# "sklearn" needs no API key and no torch - lightweight (~150-200MB), train
#   first with: cd classifier && python train_lite.py
# "local" (default if unset) needs classifier/crime_classifier/ trained first
#   (needs torch/transformers, 1GB+ install).
CLASSIFIER_BACKEND=gemini
# Get a free Gemini API key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-key-here

# --- RAG retriever (legal law lookup) ---
# "lite" needs no ML dependency at all - plain tag-filtering, reasonable
#   given legal_kb only has a handful of chunks.
# "faiss" (default if unset) needs sentence-transformers+faiss-cpu (which
#   itself needs torch) for embedding-based ranking.
# RETRIEVER_BACKEND=lite

# --- Database (optional) ---
# Leave unset for local dev - falls back to SQLite automatically.
# Set this for any real deployment (Render/Railway wipe local disk on
# restart) - use your Supabase Postgres connection string.
# DATABASE_URL=postgresql://postgres:[password]@[host]:6543/postgres

# --- File storage (optional) ---
# Leave unset for local dev - falls back to local disk automatically.
# Set both for any real deployment.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-service-role-key
# SUPABASE_BUCKET=cybercrime-files

